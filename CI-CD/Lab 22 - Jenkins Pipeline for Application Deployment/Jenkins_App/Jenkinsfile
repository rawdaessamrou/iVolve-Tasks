pipeline {
    agent any

    environment {
        IMAGE_NAME = "rawdaessamrou/jenkins-app"
        IMAGE_TAG  = "v${BUILD_NUMBER}"
        APP_DIR    = "CI-CD/Lab 22 - Jenkins Pipeline for Application Deployment/Jenkins_App"
    }

    stages {
        stage('Build App') {
            agent { docker { image 'maven:3.9.6-eclipse-temurin-17'; reuseNode true } }
            steps {
                dir("${APP_DIR}") { sh 'mvn -B clean package -DskipTests' }
            }
        }

        stage('Build & Push Image') {
            steps {
                dir("${APP_DIR}") {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                    withCredentials([usernamePassword(credentialsId: 'docker-credentials', usernameVariable: 'U', passwordVariable: 'P')]) {
                        sh "echo \$P | docker login -u \$U --password-stdin"
                        sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            agent {
                docker { 
                    image 'bitnami/kubectl:latest'
                    reuseNode true
                    // We only need the docker socket here; credentials come from Jenkins
                    args "-v /var/run/docker.sock:/var/run/docker.sock --entrypoint=''"
                }
            }
            steps {
                // configFileProvider or secret-file approach
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_PATH')]) {
                    dir("${APP_DIR}") {
                        sh "sed -i 's|image:.*|image: ${IMAGE_NAME}:${IMAGE_TAG}|' deployment.yaml"
                        // KUBECONFIG_PATH is a temporary path Jenkins creates automatically
                        sh 'kubectl --kubeconfig=$KUBECONFIG_PATH apply -f deployment.yaml'
                        sh 'kubectl --kubeconfig=$KUBECONFIG_PATH get pods'
                    }
                }
            }
        }
    }

    post {
        always { cleanWs() }
        success { echo "Deployment Finished Successfully! ✅" }
        failure { echo "Pipeline Failed. ❌" }
    }
}
