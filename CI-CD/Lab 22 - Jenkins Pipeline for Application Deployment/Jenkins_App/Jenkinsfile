pipeline {
    agent any

    environment {
        IMAGE_NAME = "rawdaessamrou/jenkins-app"
        IMAGE_TAG  = "v${BUILD_NUMBER}"
        APP_DIR    = "CI-CD/Lab 22 - Jenkins Pipeline for Application Deployment/Jenkins_App"
    }

    stages {

        // ─────────────────────────────
        // 1. Unit Tests
        // ─────────────────────────────
        stage('Unit Test') {
            agent {
                docker {
                    image 'maven:3.9.6-eclipse-temurin-17'
                    reuseNode true
                }
            }
            steps {
                dir("${APP_DIR}") {
                    sh 'mvn -B test'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: '**/target/surefire-reports/*.xml'
                }
            }
        }

        // ─────────────────────────────
        // 2. Build App
        // ─────────────────────────────
        stage('Build App') {
            agent {
                docker {
                    image 'maven:3.9.6-eclipse-temurin-17'
                    reuseNode true
                }
            }
            steps {
                dir("${APP_DIR}") {
                    sh 'mvn -B clean package -DskipTests'
                }
            }
        }

        // ─────────────────────────────
        // 3. Docker Build & Push
        // ─────────────────────────────
        stage('Build & Push Image') {
            steps {
                dir("${APP_DIR}") {

                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."

                    withCredentials([usernamePassword(
                        credentialsId: 'docker-credentials',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh '''
                            echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                        '''
                        sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
                    }
                }
            }
        }

        // ─────────────────────────────
        // 4. Cleanup Local Image
        // ─────────────────────────────
        stage('Delete Local Image') {
            steps {
                sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
            }
        }

        // ─────────────────────────────
        // 5. Deploy to Kubernetes
        // ─────────────────────────────
        stage('Deploy to Kubernetes') {
            agent {
                docker {
                    image 'bitnami/kubectl:latest'
                    reuseNode true
                    args "--entrypoint=''"
                }
            }

            steps {
                withCredentials([file(
                    credentialsId: 'kubeconfig',
                    variable: 'KUBECONFIG_FILE'
                )]) {

                    dir("${APP_DIR}") {

                        // 🔍 Debug kubeconfig (remove later)
                        sh '''
                            echo "=== KUBE SERVER ==="
                            grep server "$KUBECONFIG_FILE"
                        '''

                        // 🔧 Update image in deployment.yaml
                        sh """
                            sed -i 's|image:.*|image: ${IMAGE_NAME}:${IMAGE_TAG}|' deployment.yaml
                        """

                        // 🚀 Deploy safely (no OpenAPI validation + no TLS verification issues)
                        sh '''
                            export KUBECONFIG=$KUBECONFIG_FILE

                            kubectl config use-context minikube || true

                            kubectl apply --validate=false \
                                --insecure-skip-tls-verify=true \
                                -f deployment.yaml

                            kubectl get pods
                        '''
                    }
                }
            }
        }
    }

    // ─────────────────────────────
    // Post Actions
    // ─────────────────────────────
    post {
        always {
            cleanWs()
        }
        success {
            echo "✅ Deployment successful: ${IMAGE_NAME}:${IMAGE_TAG}"
        }
        failure {
            echo "❌ Pipeline failed"
        }
    }
}
