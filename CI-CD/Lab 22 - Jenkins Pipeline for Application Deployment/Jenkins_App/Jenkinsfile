pipeline {
    agent any

    environment {
        // Your specific data
        IMAGE_NAME = "rawdaessamrou/jenkins-app"
        IMAGE_TAG  = "v${BUILD_NUMBER}"
        APP_DIR    = "CI-CD/Lab 22 - Jenkins Pipeline for Application Deployment/Jenkins_App"
        // Adjust this path if your kubeconfig is stored elsewhere on the Jenkins server
        KUBECONFIG = '/var/lib/jenkins/.kube/config' 
    }

    stages {
        stage('Checkout Code') {
            steps {
                // Checkout the repository
                checkout scm
            }
        }

        stage('Run Unit Tests') {
            steps {
                dir("${APP_DIR}") {
                    // -B prevents hanging on dependency downloads
                    sh 'mvn -B test'
                }
            }
        }

        stage('Build App') {
            steps {
                dir("${APP_DIR}") {
                    sh 'mvn -B clean package -DskipTests'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${APP_DIR}") {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Push Image to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        docker push ${IMAGE_NAME}:${IMAGE_TAG}
                        docker image rm ${IMAGE_NAME}:${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Update deployment.yaml') {
            steps {
                dir("${APP_DIR}") {
                    // Updates the image line in your YAML file
                    sh "sed -i 's|image:.*|image: ${IMAGE_NAME}:${IMAGE_TAG}|' deployment.yaml"
                }
            }
        }

        stage('Test Kubernetes') {
            steps {
                // Verifies connection to the cluster
                sh 'kubectl --kubeconfig=${KUBECONFIG} get nodes'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                dir("${APP_DIR}") {
                    sh 'kubectl --kubeconfig=${KUBECONFIG} apply -f deployment.yaml'
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline process finished.'
            // Recommended: clean workspace to save disk space
            cleanWs()
        }
        success {
            echo 'Pipeline Finished ✅'
        }
        failure {
            echo 'Pipeline Failed ❌'
        }
    }
}
